<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <AssemblyName>claw-links</AssemblyName>
    <OutputType>Exe</OutputType>
    <RootNamespace>ClawLinks.Launcher</RootNamespace>
    <TargetFramework>net10.0</TargetFramework>
  </PropertyGroup>

  <ItemGroup>
    <Content Include="..\..\config\firefox\policies.json">
      <Link>assets\firefox\policies.json</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
</Project>
